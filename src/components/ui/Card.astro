---
import { Icon } from 'astro-icon/components';

const { icon, size } = Astro.props;
---
<div class={`flex flex-col flex-wrap bg-black/35 backdrop-blur rounded-4xl p-4 [&>*]:text-wrap w-3xs gap-2 items-center text-center`}>
     { icon == undefined ? '' :  <Icon name={`${icon}`} width={size} height={size} /> }
    <slot />
</div>
